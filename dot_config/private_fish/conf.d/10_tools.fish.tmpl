command --query fzf; and fzf --fish | source
command --query atuin; and atuin init fish --disable-up-arrow | source
command --query mise; and mise activate fish | source
command --query starship; and starship init fish | source
command --query zoxide; and zoxide init --cmd cd fish | source
command --query proto; and proto activate | source
command --query conda; and conda shell.fish hook | source

if command --query nvim
    set -x EDITOR nvim
    abbr vim nvim
    abbr vi nvim
else
    set -x EDITOR vim
    abbr vi vim
end

{{ if eq .chezmoi.os "darwin" -}}
if test -f ~/.orbstack/shell/init2.fish
    source ~/.orbstack/shell/init2.fish 2>/dev/null || :
end
set -gx PNPM_HOME "$HOME/Library/pnpm"
{{- else -}}
set -gx PNPM_HOME "$HOME/.local/share/pnpm"
{{- end }}
if not string match -q -- $PNPM_HOME $PATH
  set -gx PATH "$PNPM_HOME" $PATH
end
