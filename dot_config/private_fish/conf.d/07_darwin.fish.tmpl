set -gx HOMEBREW_INSTALL_BADGE 📦
set -gx HOMEBREW_NO_ANALYTICS 1
set -gx HOMEBREW_AUTO_UPDATE_SECS 86400

if test -z "$HOMEBREW_PREFIX"
    eval ({{(dig "brewPath" "" .) }} shellenv)
end

set -gx SSH_AUTH_SOCK ~/Library/Containers/com.maxgoedjen.Secretive.SecretAgent/Data/socket.ssh

set --erase XDG_DATA_DIRS

if test -d /opt/homebrew/opt/rustup/bin
    fish_add_path /opt/homebrew/opt/rustup/bin
end

# macOS-only aliases
abbr countdown 'mpg321 -q ~/iCloudDrive/Sounds/countdown.mp3'
abbr dotfiles "cd $HOME/iCloudDrive/Projects/dotfiles"
abbr icd "cd $HOME/iCloudDrive"
